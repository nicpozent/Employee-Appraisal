# ─────────────────────────────────────────────────────────────
# Employee Appraisal Platform — environment configuration
# Copy to `.env` and fill in real values for a live deployment.
# Leaving Entra values blank runs the app in DEV-MOCK auth mode.
# ─────────────────────────────────────────────────────────────

# --- Database ---
POSTGRES_USER=appraisal
POSTGRES_PASSWORD=appraisal
POSTGRES_DB=appraisal
POSTGRES_PORT=5432
DATABASE_URL=postgresql://appraisal:appraisal@localhost:5432/appraisal?schema=public

# --- API ---
API_PORT=4000
WEB_ORIGIN=http://localhost:5173

# --- Auth mode ---
# When AUTH_MODE=entra, the API validates real Entra ID JWTs and the SPA uses MSAL.
# When AUTH_MODE=mock (or Entra vars are empty), a dev sign-in + role switcher is used.
AUTH_MODE=mock

# --- Microsoft Entra ID (Enterprise Application) ---
# From Azure Portal > Entra ID > App registrations > your app
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# App (client) secret used for Graph application permissions (import users, sendMail).
# NEVER commit this. Use a secret store in production (Key Vault / docker secrets).
ENTRA_CLIENT_SECRET=
# Optional: audience/issuer overrides (defaults derived from tenant/client)
ENTRA_API_AUDIENCE=

# --- Microsoft Graph ---
# Application permissions required: User.Read.All, GroupMember.Read.All,
# Directory.Read.All, Mail.Send
GRAPH_SENDER_UPN=appraisals@yourtenant.onmicrosoft.com
# Comma-separated Entra security group object IDs to import users from.
ENTRA_IMPORT_GROUP_IDS=

# --- Reminders scheduler ---
# Cron for the reminder sweep (default: every day 08:00). Set REMINDERS_ENABLED=false to disable.
REMINDERS_ENABLED=true
REMINDERS_CRON=0 8 * * *
# Send a reminder when a step deadline is within N days.
REMINDER_LEAD_DAYS=3

# --- Frontend (Vite) — these are injected at build/runtime for the SPA ---
VITE_API_BASE=http://localhost:4000
VITE_AUTH_MODE=mock
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_API_SCOPE=
